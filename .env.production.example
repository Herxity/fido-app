# Compose release inputs. Images must use immutable sha256 digests.
BACKEND_IMAGE=ghcr.io/herxity/fido-app-backend@sha256:replace_with_64_hex_characters
CADDY_IMAGE=caddy@sha256:replace_with_64_hex_characters
FIDO_RELEASE_DIR=/opt/fido/releases/replace_with_commit_sha
ORIGIN_HOSTNAME=replace-with-static-ip-dashes.sslip.io
FIDO_ORIGIN_VERIFY_TOKEN=replace_with_at_least_32_random_characters

# Backend settings. Keep the real file at /etc/fido/fido.env, owned by root and mode 0600.
FIDO_ENVIRONMENT=production
FIDO_PROVIDER_MODE=live
FIDO_DATABASE_URL=postgresql+psycopg://fido_runtime:replace@private-database-host:5432/fido
FIDO_CORS_ORIGINS=["https://app.example.org"]
FIDO_CLERK_ISSUER=https://replace.clerk.accounts.dev
FIDO_CLERK_AUDIENCE=
FIDO_CLERK_JWKS_URL=https://replace.clerk.accounts.dev/.well-known/jwks.json
FIDO_CLERK_AUTHORIZED_PARTIES=["https://app.example.org"]
FIDO_CLERK_ALLOW_LEGACY_ORG_CLAIMS=false
FIDO_CLERK_WEBHOOK_SECRET=replace
FIDO_STRIPE_SECRET_KEY=replace
FIDO_STRIPE_IDENTITY_RESTRICTED_KEY=replace
FIDO_STRIPE_WEBHOOK_SECRET=replace
FIDO_STRIPE_VERIFICATION_FLOW_ID=
FIDO_STRIPE_REQUIRE_ID_NUMBER=false
FIDO_IDENTITY_HASH_KEY=replace
FIDO_FIELD_ENCRYPTION_KEY=replace_with_fernet_key
FIDO_LOOKUP_HASH_KEY=replace_with_random_key
FIDO_WEBHOOK_TOLERANCE_SECONDS=300
FIDO_REQUEST_BODY_LIMIT=1048576
