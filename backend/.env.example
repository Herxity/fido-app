FIDO_ENVIRONMENT=development
FIDO_DATABASE_URL=postgresql+psycopg://fido:fido@localhost:5432/fido
FIDO_CORS_ORIGINS=["http://localhost:5173"]
FIDO_CLERK_ISSUER=https://example.clerk.accounts.dev
FIDO_CLERK_AUDIENCE=
FIDO_CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
FIDO_CLERK_AUTHORIZED_PARTIES=["https://app.example.com"]
FIDO_CLERK_ALLOW_LEGACY_ORG_CLAIMS=false
FIDO_CLERK_WEBHOOK_SECRET=replace-with-whsec-secret
FIDO_PERSONA_API_BASE=https://api.withpersona.com/api/v1
